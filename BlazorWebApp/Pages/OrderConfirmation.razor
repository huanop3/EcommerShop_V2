@page "/order-confirmation"
@page "/order-confirmation/{orderId:int?}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using BlazorWebApp.Services
@using MainEcommerceService.Models.ViewModel
@using ProductService.Models.ViewModel
@using System.Text.Json
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject OrderService OrderService
@inject SignalRService SignalRService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject ToastService ToastService
@attribute [Authorize]
@implements IAsyncDisposable

<PageTitle>Order Confirmation - Grabit</PageTitle>
<link href="css/order-confirmation.css" rel="stylesheet" />

<div class="order-confirmation-container">
    @if (isLoading)
    {
        <div class="loading-section">
            <div class="loading-content">
                <div class="loading-spinner"></div>
                <h3>Loading your order...</h3>
                <p>Please wait while we load your order details</p>
            </div>
        </div>
    }
    else if (orderData == null)
    {
        <div class="error-section">
            <div class="error-content">
                <div class="error-icon">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                <h3>Order Not Found</h3>
                <p>We couldn't find your order information. Please try again.</p>
                <div class="error-actions">
                    <a href="/orders" class="btn btn-primary">
                        <i class="fas fa-list"></i>
                        View My Orders
                    </a>
                    <a href="/cart" class="btn btn-secondary">
                        <i class="fas fa-shopping-cart"></i>
                        Back to Cart
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Order Confirmation Header -->
        <div class="confirmation-header">
            <div class="success-animation">
                <div class="checkmark-circle">
                    <div class="checkmark"></div>
                </div>
            </div>
            <h1 class="confirmation-title">Order Confirmed!</h1>
            <p class="confirmation-subtitle">Thank you for your order. We're processing it now.</p>
            @if (!string.IsNullOrEmpty(orderData.OrderNumber))
            {
                <div class="order-number">
                    <span class="label">Order Number:</span>
                    <span class="number">#@orderData.OrderNumber</span>
                </div>
            }
        </div>

        <!-- Real-time Order Status Tracking -->
        <div class="order-tracking-section">
            <h3 class="section-title">
                <i class="fas fa-truck"></i>
                Order Status
            </h3>
            
            <div class="order-status-tracker">
                <div class="status-step @(currentStep >= 1 ? "completed" : "")">
                    <div class="step-circle">
                        @if (currentStep > 1)
                        {
                            <i class="fas fa-check"></i>
                        }
                        else
                        {
                            <span>1</span>
                        }
                    </div>
                    <div class="step-content">
                        <h4>Order Received</h4>
                        <p>@orderData.OrderDate.ToString("MMM dd, yyyy - HH:mm")</p>
                        @if (orderReceivedAt.HasValue)
                        {
                            <small>Confirmed at @orderReceivedAt.Value.ToString("HH:mm")</small>
                        }
                    </div>
                </div>

                <div class="status-connector @(currentStep >= 2 ? "active" : "")"></div>

                <div class="status-step @(currentStep >= 2 ? currentStep > 2 ? "completed" : "active" : "")">
                    <div class="step-circle">
                        @if (currentStep > 2)
                        {
                            <i class="fas fa-check"></i>
                        }
                        else if (currentStep == 2)
                        {
                            <div class="spinner"></div>
                        }
                        else
                        {
                            <span>2</span>
                        }
                    </div>
                    <div class="step-content">
                        <h4>Processing</h4>
                        <p>
                            @if (currentStep == 2)
                            {
                                <span class="processing-text">Verifying inventory and processing payment...</span>
                            }
                            else if (currentStep > 2)
                            {
                                <span>Order verified and confirmed</span>
                            }
                            else
                            {
                                <span>Pending verification</span>
                            }
                        </p>
                        @if (processingCompletedAt.HasValue)
                        {
                            <small>Completed at @processingCompletedAt.Value.ToString("HH:mm")</small>
                        }
                    </div>
                </div>

                <div class="status-connector @(currentStep >= 3 ? "active" : "")"></div>

                <div class="status-step @(currentStep >= 3 ? currentStep > 3 ? "completed" : "active" : "")">
                    <div class="step-circle">
                        @if (currentStep > 3)
                        {
                            <i class="fas fa-check"></i>
                        }
                        else if (currentStep == 3)
                        {
                            <div class="spinner"></div>
                        }
                        else
                        {
                            <span>3</span>
                        }
                    </div>
                    <div class="step-content">
                        <h4>Preparing</h4>
                        <p>
                            @if (currentStep == 3)
                            {
                                <span class="processing-text">Items are being prepared for shipment...</span>
                            }
                            else if (currentStep > 3)
                            {
                                <span>Ready for delivery</span>
                            }
                            else
                            {
                                <span>Waiting for processing to complete</span>
                            }
                        </p>
                        @if (preparingCompletedAt.HasValue)
                        {
                            <small>Completed at @preparingCompletedAt.Value.ToString("HH:mm")</small>
                        }
                    </div>
                </div>

                <div class="status-connector @(currentStep >= 4 ? "active" : "")"></div>

                <div class="status-step @(currentStep >= 4 ? "active" : "")">
                    <div class="step-circle">
                        @if (currentStep >= 4)
                        {
                            <i class="fas fa-truck"></i>
                        }
                        else
                        {
                            <span>4</span>
                        }
                    </div>
                    <div class="step-content">
                        <h4>Ready for Delivery</h4>
                        <p>
                            @if (currentStep >= 4)
                            {
                                <span>Your order is ready for delivery</span>
                            }
                            else
                            {
                                <span>Estimated: @GetEstimatedDeliveryTime()</span>
                            }
                        </p>
                        @if (readyForDeliveryAt.HasValue)
                        {
                            <small>Ready at @readyForDeliveryAt.Value.ToString("HH:mm")</small>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Real-time Updates -->
        <div class="real-time-updates">
            <h3 class="section-title">
                <i class="fas fa-bell"></i>
                Real-time Updates
                @if (signalRConnected)
                {
                    <span class="connection-status connected">
                        <i class="fas fa-circle"></i> Connected
                    </span>
                }
                else
                {
                    <span class="connection-status disconnected">
                        <i class="fas fa-circle"></i> Disconnected
                    </span>
                }
            </h3>
            
            <div class="updates-timeline">
                @if (orderUpdates.Any())
                {
                    @foreach (var update in orderUpdates.OrderByDescending(u => u.Timestamp))
                    {
                        <div class="update-item @update.Type">
                            <div class="update-icon">
                                @switch (update.Type)
                                {
                                    case "success":
                                        <i class="fas fa-check-circle"></i>
                                        break;
                                    case "info":
                                        <i class="fas fa-info-circle"></i>
                                        break;
                                    case "warning":
                                        <i class="fas fa-exclamation-triangle"></i>
                                        break;
                                    case "error":
                                        <i class="fas fa-times-circle"></i>
                                        break;
                                    default:
                                        <i class="fas fa-circle"></i>
                                        break;
                                }
                            </div>
                            <div class="update-content">
                                <h4>@update.Title</h4>
                                <p>@update.Message</p>
                                <small>@update.Timestamp.ToString("HH:mm:ss")</small>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="no-updates">
                        <i class="fas fa-clock"></i>
                        <p>Waiting for order updates...</p>
                    </div>
                }
            </div>
        </div>

        <!-- Order Details -->
        <div class="order-details-section">
            <div class="details-grid">
                <!-- Order Summary -->
                <div class="detail-card">
                    <h3 class="card-title">
                        <i class="fas fa-receipt"></i>
                        Order Summary
                    </h3>
                    <div class="order-items">
                        @if (orderData.Items != null && orderData.Items.Any())
                        {
                            @foreach (var item in orderData.Items)
                            {
                                <div class="order-item">
                                    <div class="item-image">
                                        <img src="@GetProductImageUrl(item)" alt="@item.ProductName" />
                                    </div>
                                    <div class="item-info">
                                        <h4>@item.ProductName</h4>
                                        <p>Qty: @item.CartQuantity × $@item.UnitPrice.ToString("F2")</p>
                                    </div>
                                    <div class="item-total">
                                        $@item.TotalPrice.ToString("F2")
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    
                    @if (orderData.Pricing != null)
                    {
                        <div class="pricing-summary">
                            <div class="pricing-row">
                                <span>Subtotal:</span>
                                <span>$@orderData.Pricing.Subtotal.ToString("F2")</span>
                            </div>
                            @if (orderData.Pricing.CouponDiscount > 0)
                            {
                                <div class="pricing-row discount">
                                    <span>Discount:</span>
                                    <span>-$@orderData.Pricing.CouponDiscount.ToString("F2")</span>
                                </div>
                            }
                            <div class="pricing-row">
                                <span>Shipping:</span>
                                <span>
                                    @if (orderData.Pricing.IsFreeShipping)
                                    {
                                        <span class="free">FREE</span>
                                    }
                                    else
                                    {
                                        <text>$@orderData.Pricing.ShippingCost.ToString("F2")</text>
                                    }
                                </span>
                            </div>
                            <div class="pricing-row total">
                                <span>Total:</span>
                                <span>$@orderData.Pricing.TotalAmount.ToString("F2")</span>
                            </div>
                        </div>
                    }
                </div>

                <!-- Delivery Information -->
                <div class="detail-card">
                    <h3 class="card-title">
                        <i class="fas fa-map-marker-alt"></i>
                        Delivery Information
                    </h3>
                    @if (orderData.ShippingAddress != null)
                    {
                        <div class="address-info">
                            <p><strong>@orderData.ShippingAddress.AddressLine1</strong></p>
                            @if (!string.IsNullOrEmpty(orderData.ShippingAddress.AddressLine2))
                            {
                                <p>@orderData.ShippingAddress.AddressLine2</p>
                            }
                            <p>@orderData.ShippingAddress.City, @orderData.ShippingAddress.State @orderData.ShippingAddress.PostalCode</p>
                            <p>@orderData.ShippingAddress.Country</p>
                        </div>
                    }
                    
                    <div class="delivery-info">
                        <div class="info-row">
                            <span class="label">Delivery Option:</span>
                            <span class="value">@GetDeliveryOptionName(orderData.DeliveryOption)</span>
                        </div>
                        <div class="info-row">
                            <span class="label">Payment Method:</span>
                            <span class="value">@GetPaymentMethodName(orderData.PaymentMethod)</span>
                        </div>
                        @if (!string.IsNullOrEmpty(orderData.DeliveryInstructions))
                        {
                            <div class="info-row">
                                <span class="label">Instructions:</span>
                                <span class="value">@orderData.DeliveryInstructions</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="order-actions">
            <a href="/orders" class="btn btn-primary">
                <i class="fas fa-list"></i>
                View All Orders
            </a>
            <a href="/products" class="btn btn-secondary">
                <i class="fas fa-shopping-bag"></i>
                Continue Shopping
            </a>
            @if (currentStep < 4 && orderProcessed)
            {
                <button class="btn btn-info" @onclick="RefreshOrderStatus">
                    <i class="fas fa-sync-alt"></i>
                    Refresh Status
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int? OrderId { get; set; }

    // Order data from static service or API
    private OrderDataModel? orderData;
    private int? currentUserId;
    
    // Order tracking state
    private int currentStep = 1;
    private bool orderProcessed = false;
    private bool signalRConnected = false;
    private bool disposed = false;
    
    // Timestamps
    private DateTime? orderReceivedAt;
    private DateTime? processingCompletedAt;
    private DateTime? preparingCompletedAt;
    private DateTime? readyForDeliveryAt;
    
    // Real-time updates
    private List<OrderUpdateModel> orderUpdates = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await GetCurrentUserIdAsync();
            if (!currentUserId.HasValue)
            {
                Navigation.NavigateTo("/login", true);
                return;
            }

            await LoadOrderDataAsync();
            await InitializeSignalRAsync();
            await InitializeOrderStateAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error in OnInitializedAsync: {ex.Message}");
            ToastService.ShowError("Error loading order confirmation");
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task GetCurrentUserIdAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var userIdClaim = user.Claims.FirstOrDefault(c => c.Type == "UserId");
                if (userIdClaim != null && int.TryParse(userIdClaim.Value, out int userId))
                {
                    currentUserId = userId;
                    Console.WriteLine($"✅ Current User ID: {currentUserId}");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error getting current user: {ex.Message}");
        }
    }

    private async Task LoadOrderDataAsync()
    {
        try
        {
            // First, try to get from OrderStateService (just placed order)
            orderData = OrderStateService.GetOrderData();
            
            // If no data and we have OrderId parameter, load from API
            if (orderData == null && OrderId.HasValue)
            {
                var orderResult = await OrderService.GetOrderByIdAsync(OrderId.Value);
                if (orderResult != null)
                {
                    orderData = ConvertOrderVMToOrderData(orderResult);
                    Console.WriteLine($"✅ Loaded order from API: {OrderId}");
                }
            }
            
            // If still no data, try to get the latest order for this user
            if (orderData == null && currentUserId.HasValue)
            {
                var userOrdersResult = await OrderService.GetOrdersByUserIdAsync(currentUserId.Value);
                if (userOrdersResult?.Any() == true)
                {
                    var latestOrder = userOrdersResult.OrderByDescending(o => o.CreatedAt).FirstOrDefault();
                    if (latestOrder != null)
                    {
                        orderData = ConvertOrderVMToOrderData(latestOrder);
                        OrderId = latestOrder.OrderId; // Set OrderId for tracking
                        Console.WriteLine($"✅ Loaded latest order for user: {OrderId}");
                    }
                }
            }

            // Generate order number if needed
            if (orderData != null && string.IsNullOrEmpty(orderData.OrderNumber))
            {
                orderData.OrderNumber = $"ORD-{DateTime.Now:yyyyMMdd}-{Random.Shared.Next(1000, 9999)}";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error loading order data: {ex.Message}");
        }
    }

    private async Task InitializeSignalRAsync()
    {
        try
        {
            Console.WriteLine("🚀 Initializing SignalR connection...");

            // Subscribe to order events
            SignalRService.OrderCreated += OnOrderCreated;
            SignalRService.OrderStatusChanged += OnOrderStatusChanged;
            SignalRService.YourOrderCreated += OnYourOrderCreated;
            SignalRService.YourOrderStatusChanged += OnYourOrderStatusChanged;
            
            // ✅ SỬA: Subscribe to Kafka events
            SignalRService.OrderConfirmed += OnOrderConfirmed;
            SignalRService.OrderCancelled += OnOrderCancelled;
            SignalRService.YourOrderConfirmed += OnYourOrderConfirmed;
            SignalRService.YourOrderCancelled += OnYourOrderCancelled;
            
            Console.WriteLine("✅ Event handlers subscribed");

            // Start connection if not already connected
            if (!SignalRService.IsMainHubConnected)
            {
                await SignalRService.StartConnectionAsync();
                await Task.Delay(2000);
            }

            // Register user
            if (currentUserId.HasValue)
            {
                await SignalRService.RegisterUserConnectionAsync(currentUserId.Value.ToString());
            }
            
            signalRConnected = SignalRService.IsMainHubConnected;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ SignalR initialization error: {ex.Message}");
        }
    }

    private async Task InitializeOrderStateAsync()
    {
        // Set initial state
        currentStep = 1;
        orderReceivedAt = DateTime.Now;
        AddOrderUpdate("info", "Order Received", "Your order has been received and is being processed");
        
        await Task.Delay(1000);
        
        // Move to processing step
        currentStep = 2;
        AddOrderUpdate("info", "Processing Started", "Your order is now being processed. Please wait for confirmation...");
        await InvokeAsync(StateHasChanged);
    }

    // 🔥 SỬA: Cải tiến event handlers với better error handling
    private void OnOrderCreated(int orderId, int userId, decimal totalAmount)
    {
        if (disposed) return;
        
        try
        {
            if (userId == currentUserId || OrderId == orderId)
            {
                InvokeAsync(() =>
                {
                    AddOrderUpdate("success", "Order Created", $"Order #{orderId} has been created successfully!");
                    currentStep = Math.Max(currentStep, 1);
                    orderReceivedAt = DateTime.Now;
                    StateHasChanged();
                });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error in OnOrderCreated: {ex.Message}");
        }
    }

    private void OnYourOrderCreated(int orderId, decimal totalAmount, string message)
    {
        if (disposed) return;
        
        try
        {
            InvokeAsync(() =>
            {
                AddOrderUpdate("success", "Order Confirmed", $"Your order #{orderId} for ${totalAmount:F2} has been created");
                currentStep = Math.Max(currentStep, 1);
                orderReceivedAt = DateTime.Now;
                
                // Set OrderId if not already set
                if (!OrderId.HasValue)
                {
                    OrderId = orderId;
                }
                
                StateHasChanged();
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error in OnYourOrderCreated: {ex.Message}");
        }
    }

    private void OnOrderStatusChanged(int orderId, int userId, int statusId, string status)
    {
        if (disposed) return;
        
        try
        {
            if (userId == currentUserId || OrderId == orderId)
            {
                InvokeAsync(() =>
                {
                    AddOrderUpdate("info", "Status Update", $"Order #{orderId} status changed to: {status}");
                    UpdateStepFromStatus(status);
                    StateHasChanged();
                });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error in OnOrderStatusChanged: {ex.Message}");
        }
    }

    private void OnYourOrderStatusChanged(int orderId, string statusName, string message)
    {
        if (disposed) return;
        
        try
        {
            if (OrderId == orderId || !OrderId.HasValue)
            {
                InvokeAsync(() =>
                {
                    AddOrderUpdate("info", "Your Order Updated", message ?? $"Order status: {statusName}");
                    UpdateStepFromStatus(statusName);
                    StateHasChanged();
                });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error in OnYourOrderStatusChanged: {ex.Message}");
        }
    }

    // 🔥 SỬA: Cải tiến Kafka event handlers
    private void OnOrderConfirmed(int orderId)
    {
        Console.WriteLine($"🎉 PAGE: OrderConfirmed event received for order {orderId}");
        
        if (disposed) return;
        
        try
        {
            if (OrderId == orderId )
            {
                InvokeAsync(() =>
                {
                    currentStep = 3;
                    processingCompletedAt = DateTime.Now;
                    orderProcessed = true;
                    AddOrderUpdate("success", "Order Confirmed", "Your order has been confirmed and is being prepared!");
                    StateHasChanged();
                });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error in OnOrderConfirmed: {ex.Message}");
        }
    }

    private void OnOrderCancelled(int orderId, string reason)
    {
        Console.WriteLine($"❌ PAGE: OrderCancelled event received for order {orderId}, reason: {reason}");
        
        if (disposed) return;
        
        try
        {
            if (OrderId == orderId )
            {
                InvokeAsync(() =>
                {
                    currentStep = 0;
                    orderProcessed = false;
                    AddOrderUpdate("error", "Order Cancelled", $"Your order has been cancelled: {reason}");
                    StateHasChanged();
                });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error in OnOrderCancelled: {ex.Message}");
        }
    }

    // ✅ THÊM: Your order specific handlers
    private void OnYourOrderConfirmed(int orderId, string message)
    {
        Console.WriteLine($"🎉 PAGE: YourOrderConfirmed event received for order {orderId}: {message}");
        
        if (disposed) return;
        
        try
        {
            if (OrderId == orderId )
            {
                InvokeAsync(() =>
                {
                    currentStep = 3;
                    processingCompletedAt = DateTime.Now;
                    orderProcessed = true;
                    AddOrderUpdate("success", "Order Confirmed", message);
                    StateHasChanged();
                });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error in OnYourOrderConfirmed: {ex.Message}");
        }
    }

    private void OnYourOrderCancelled(int orderId, string reason, string message)
    {
        Console.WriteLine($"❌ PAGE: YourOrderCancelled event received for order {orderId}: {message}");
        
        if (disposed) return;
        
        try
        {
            if (OrderId == orderId )
            {
                InvokeAsync(() =>
                {
                    currentStep = 0;
                    orderProcessed = false;
                    AddOrderUpdate("error", "Order Cancelled", message);
                    StateHasChanged();
                });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error in OnYourOrderCancelled: {ex.Message}");
        }
    }

    // ✅ SỬA: Cleanup
    public async ValueTask DisposeAsync()
    {
        try
        {
            disposed = true;
            
            if (SignalRService != null)
            {
                SignalRService.OrderCreated -= OnOrderCreated;
                SignalRService.OrderStatusChanged -= OnOrderStatusChanged;
                SignalRService.YourOrderCreated -= OnYourOrderCreated;
                SignalRService.YourOrderStatusChanged -= OnYourOrderStatusChanged;
                
                // ✅ THÊM: Unsubscribe Kafka events
                SignalRService.OrderConfirmed -= OnOrderConfirmed;
                SignalRService.OrderCancelled -= OnOrderCancelled;
                SignalRService.YourOrderConfirmed -= OnYourOrderConfirmed;
                SignalRService.YourOrderCancelled -= OnYourOrderCancelled;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error disposing OrderConfirmation: {ex.Message}");
        }
    }

    private void UpdateStepFromStatus(string statusName)
    {
        if (string.IsNullOrEmpty(statusName)) return;
        
        var previousStep = currentStep;
        
        switch (statusName.ToLower())
        {
            case "pending":
                currentStep = Math.Max(currentStep, 1);
                break;
            case "processing":
                currentStep = Math.Max(currentStep, 2);
                break;
            case "confirmed":
                currentStep = Math.Max(currentStep, 3);
                processingCompletedAt = DateTime.Now;
                orderProcessed = true;
                break;
            case "preparing":
            case "packaged":
                currentStep = Math.Max(currentStep, 3);
                preparingCompletedAt = DateTime.Now;
                break;
            case "ready":
            case "shipped":
            case "out_for_delivery":
                currentStep = Math.Max(currentStep, 4);
                readyForDeliveryAt = DateTime.Now;
                orderProcessed = true;
                break;
            case "delivered":
                currentStep = 5;
                orderProcessed = true;
                AddOrderUpdate("success", "Order Delivered", "Your order has been delivered successfully!");
                break;
            case "cancelled":
                AddOrderUpdate("error", "Order Cancelled", "Your order has been cancelled.");
                currentStep = 1;
                orderProcessed = false;
                break;
        }
        
        if (currentStep != previousStep)
        {
            Console.WriteLine($"📊 Step updated from {previousStep} to {currentStep} for status: {statusName}");
        }
    }

    private void AddOrderUpdate(string type, string title, string message)
    {
        orderUpdates.Add(new OrderUpdateModel
        {
            Type = type,
            Title = title,
            Message = message,
            Timestamp = DateTime.Now
        });
        
        // Keep only last 10 updates
        if (orderUpdates.Count > 10)
        {
            orderUpdates = orderUpdates.Skip(orderUpdates.Count - 10).ToList();
        }
        
        Console.WriteLine($"📝 Added update: [{type}] {title} - {message}");
    }

    private async Task RefreshOrderStatus()
    {
        try
        {
            if (OrderId.HasValue)
            {
                var result = await OrderService.GetOrderByIdAsync(OrderId.Value);
                if (result != null)
                {
                    AddOrderUpdate("info", "Status Refreshed", "Order status has been refreshed");
                    // Map StatusId to step if needed
                    switch (result.OrderStatusId)
                    {
                        case 1: // Pending
                            UpdateStepFromStatus("pending");
                            break;
                        case 2: // Confirmed
                            UpdateStepFromStatus("confirmed");
                            break;
                        case 8: // Cancelled
                            UpdateStepFromStatus("cancelled");
                            break;
                    }
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error refreshing status: {ex.Message}");
            AddOrderUpdate("warning", "Refresh Failed", "Unable to refresh order status");
        }
    }

    private OrderDataModel ConvertOrderVMToOrderData(OrderVM orderVM)
    {
        return new OrderDataModel
        {
            OrderNumber = $"ORD-{orderVM.OrderId}",
            OrderDate = orderVM.CreatedAt ?? DateTime.Now,
            UserId = orderVM.UserId,
            Items = new List<CartVM>(),
            Pricing = new PricingBreakdown
            {
                TotalAmount = orderVM.TotalAmount,
                Subtotal = orderVM.TotalAmount,
                ShippingCost = 0,
                CouponDiscount = 0,
                TotalQuantity = 1,
                IsFreeShipping = true
            }
        };
    }

